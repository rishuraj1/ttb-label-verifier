# generate a random secret: https://generate-secret.vercel.app/32 or `openssl rand -base64 32`
AUTH_SECRET=****

# PostgreSQL — required for username/password accounts
# Local dev: your hosted or local Postgres URL
# Docker Compose: postgres://ttb:ttb@db:5432/ttb (set automatically in docker-compose.yml)
POSTGRES_URL=****

# required for label verification (Claude vision)
# https://console.anthropic.com/
ANTHROPIC_API_KEY=****
